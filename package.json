{
  "name": "poe2-rag-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/server/main.ts",
    "dev:http": "tsx src/server/http.ts",
    "start": "node dist/server/main.js",
    "start:http": "node dist/server/http.js",
    "check": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "test": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:unit": "tsx --test tests/unit/**/*.test.ts",
    "test:integration": "tsx --test tests/integration/**/*.test.ts",
    "test:e2e": "tsx --test tests/e2e/**/*.test.ts",
    "inspector": "npx @modelcontextprotocol/inspector --transport http --server-url http://localhost:3001/mcp"
  },
  "dependencies": {
    "@chroma-core/default-embed": "^0.1.9",
    "@langchain/core": "^1.1.49",
    "@langchain/langgraph": "^1.4.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chromadb": "^3.4.3",
    "dotenv": "^17.4.2",
    "fast-glob": "^3.3.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.10.0",
    "eslint": "^10.5.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  }
}
